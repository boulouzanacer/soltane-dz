              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/commandes", "host": ["{{baseUrl}}"], "path": ["api", "v1", "commandes"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_frs\": 1,\n  \"adresse_livraison\": \"Adresse\",\n  \"id_wilaya\": 16,\n  \"id_commune\": 535,\n  \"notes\": \"\",\n  \"panier\": [\n    { \"id_produit\": 1, \"quantite\": 1 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Mes commandes",
          "request": {
            "method": "GET",
