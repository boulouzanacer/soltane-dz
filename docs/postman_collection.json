              "path": ["api", "v1", "produits"],
              "query": [
                { "key": "frs_id", "value": "1" },
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Produit détail",
          "request": {
            "method": "GET",
