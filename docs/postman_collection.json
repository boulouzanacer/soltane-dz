    "name": "SafeSoft G2D API v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" },
    { "key": "clientToken", "value": "" },
    { "key": "pmeToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth Client",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Test\",\n  \"prenom\": \"Client\",\n  \"email\": \"client@test.com\",\n  \"password\": \"Password@123\",\n  \"telephone\": \"0550000000\",\n  \"type_client\": \"simple\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"client@test.com\",\n  \"password\": \"Password@123\"\n}" }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clientToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "me"] }
          }
        },
        {
          "name": "Update Profil",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clientToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/profil", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "profil"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Test\",\n  \"prenom\": \"Client\",\n  \"telephone\": \"0550000000\",\n  \"adresse\": \"Adresse\",\n  \"id_wilaya\": 16,\n  \"id_commune\": 535\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{clientToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "logout"] }
          }
        }
      ]
