            "url": { "raw": "{{baseUrl}}/api/v1/pme/sync-clients", "host": ["{{baseUrl}}"], "path": ["api", "v1", "pme", "sync-clients"] },
            "body": { "mode": "raw", "raw": "{\n  \"clients\": []\n}" }
          }
        },
        {
          "name": "Sync produits",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{pmeToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/pme/sync-produits", "host": ["{{baseUrl}}"], "path": ["api", "v1", "pme", "sync-produits"] },
            "body": { "mode": "raw", "raw": "{\n  \"produits\": []\n}" }
          }
        },
        {
          "name": "Commandes à synchroniser",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{pmeToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/pme/commandes?synced=0", "host": ["{{baseUrl}}"], "path": ["api", "v1", "pme", "commandes"], "query": [{ "key": "synced", "value": "0" }] }
          }
